# =========================
# Core service wiring
# =========================
GATEWAY_BASE_URL=http://gateway:8100
GATEWAY_API_KEY=change-me-please
GATEWAY_INTERNAL_API_KEY=change-me-please
SANDBOX_INTERNAL_API_KEY=change-me-please

# =========================
# Gateway security/runtime
# =========================
GATEWAY_TOKEN_ISSUER_SECRET=change-me-please
GATEWAY_JWT_ALGORITHM=HS256
GATEWAY_TOKEN_TTL_SECONDS=1800
GATEWAY_REDIS_URL=redis://redis:6379/0
GATEWAY_REDIS_PREFIX=gw
GATEWAY_TIMEOUT_SECONDS=300

# =========================
# Upstream LLM provider (gateway -> model API)
# =========================
API_BASE=https://api.openai.com/v1
API_KEY=change-me-please
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
TEMPERATURE=0.7
MAX_TOKENS=2000
# EXTRA_HEADERS={"X-Custom-Header":"value"}

# =========================
# Backend data stores
# =========================
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=manus
MONGODB_USERNAME=
MONGODB_PASSWORD=

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =========================
# Sandbox defaults
# =========================
SANDBOX_IMAGE=simpleyyt/manus-sandbox
SANDBOX_NAME_PREFIX=sandbox
SANDBOX_TTL_MINUTES=30
SANDBOX_NETWORK=manus-network
# SANDBOX_ADDRESS=
# SANDBOX_CHROME_ARGS=
# SANDBOX_HTTPS_PROXY=
# SANDBOX_HTTP_PROXY=
# SANDBOX_NO_PROXY=
# SANDBOX_APT_MIRROR=http://mirrors.aliyun.com/ubuntu-ports/
# SANDBOX_INSTALL_CJK_FONTS=true

# Browser engine: playwright | browser_use
BROWSER_ENGINE=playwright

# Search provider: baidu | baidu_web | google | bing | bing_web | tavily
SEARCH_PROVIDER=bing_web
# BAIDU_SEARCH_API_KEY=
# BING_SEARCH_API_KEY=
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=
# TAVILY_API_KEY=

# =========================
# Auth/JWT
# =========================
# AUTH_PROVIDER: password | none | local
AUTH_PROVIDER=password
PASSWORD_SALT=
PASSWORD_HASH_ROUNDS=10
# LOCAL_AUTH_EMAIL=admin@example.com
# LOCAL_AUTH_PASSWORD=admin

JWT_SECRET_KEY=change-me-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================
# Email (used when AUTH_PROVIDER=password)
# =========================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=your-email@gmail.com
# EMAIL_PASSWORD=your-password
# EMAIL_FROM=your-email@gmail.com

# =========================
# Misc
# =========================
# MCP_CONFIG_PATH=/etc/mcp.json
LOG_LEVEL=INFO
