# Gateway runtime configuration
# GATEWAY_BASE_URL=http://host.docker.internal:4300
GATEWAY_API_KEY=change-me-please
# GATEWAY_TIMEOUT_SECONDS=300

# Gateway service (used by gateway container)
GATEWAY_INTERNAL_API_KEY=change-me-please
# GATEWAY_TOKEN_ISSUER_SECRET=change-me
# GATEWAY_JWT_ALGORITHM=HS256
# GATEWAY_TOKEN_TTL_SECONDS=1800
# GATEWAY_REDIS_URL=redis://redis:6379/0
# GATEWAY_REDIS_PREFIX=gw
# UPSTREAM_API_BASE=
# UPSTREAM_API_KEY=
# UPSTREAM_MODEL_NAME=gpt-4o-mini
# UPSTREAM_TIMEOUT_SECONDS=120

# MongoDB configuration
#MONGODB_URI=mongodb://mongodb:27017
#MONGODB_DATABASE=manus
#MONGODB_USERNAME=
#MONGODB_PASSWORD=

# Redis configuration
#REDIS_HOST=redis
#REDIS_PORT=6379
#REDIS_DB=0
#REDIS_PASSWORD=

# Sandbox configuration
#SANDBOX_ADDRESS=
SANDBOX_INTERNAL_API_KEY=change-me-please
SANDBOX_IMAGE=simpleyyt/manus-sandbox
SANDBOX_NAME_PREFIX=sandbox
SANDBOX_TTL_MINUTES=30
SANDBOX_NETWORK=manus-network
#SANDBOX_CHROME_ARGS=
#SANDBOX_HTTPS_PROXY=
#SANDBOX_HTTP_PROXY=
#SANDBOX_NO_PROXY=
#SANDBOX_APT_MIRROR=http://mirrors.aliyun.com/ubuntu-ports/
#SANDBOX_INSTALL_CJK_FONTS=true

# Browser engine configuration
# Options: playwright (default), browser_use
# - playwright:   uses Playwright directly via CDP (stable, well-tested)
# - browser_use:  uses the browser_use library's BrowserSession via CDP
#                 (richer DOM state extraction via AI-friendly selector map)
#BROWSER_ENGINE=playwright

# Auth configuration
# Options: password, none, local
AUTH_PROVIDER=password

# Password auth configuration, only used when AUTH_PROVIDER=password
PASSWORD_SALT=
PASSWORD_HASH_ROUNDS=10

# Local auth configuration, only used when AUTH_PROVIDER=local
#LOCAL_AUTH_EMAIL=admin@example.com
#LOCAL_AUTH_PASSWORD=admin

# JWT configuration
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email configuration
# Only used when AUTH_PROVIDER=password
#EMAIL_HOST=smtp.gmail.com
#EMAIL_PORT=587
#EMAIL_USERNAME=your-email@gmail.com
#EMAIL_PASSWORD=your-password
#EMAIL_FROM=your-email@gmail.com

# Log configuration
LOG_LEVEL=INFO
